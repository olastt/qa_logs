# Скопируйте в .env и подставьте свои токены (не коммитьте .env)

# Hetzner (kube-dev)
GLITCHTIP_HETZNER_URL=https://glitchtip.kube-dev.vetmanager.cloud
GLITCHTIP_HETZNER_TOKEN=

# Selectel
GLITCHTIP_SELECTEL_URL=https://glitchtip.kube-selectel.vetmanager.ru
GLITCHTIP_SELECTEL_TOKEN=

# Организация в Glitchtip (slug из API projects[].organization.slug)
GLITCHTIP_ORG_SLUG=vetmanager

# Опрос API, секунды
POLL_INTERVAL_SEC=300

# SQLite для «уже видели» issue id
STATE_DB_PATH=data/state.db

# Уведомления (позже: Telegram / Slack / email)
# NOTIFIER_TELEGRAM_BOT_TOKEN=
# NOTIFIER_TELEGRAM_CHAT_ID=

# Запуск GitHub Actions из Bitrix (см. docs/bitrix-github-trigger.md)
# GITHUB_TOKEN=ghp_...          # PAT: repo + actions:write
# GITHUB_REPO=olastt/qa_logs
# BITRIX_TRIGGER_SECRET=...      # для scripts/bitrix_webhook_server.py
